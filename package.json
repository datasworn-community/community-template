{
  "name": "@datasworn-community/community-template",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Template repository for Datasworn community content packages.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datasworn-community/community-template.git"
  },
  "scripts": {
    "build": "datasworn-build --config datasworn.config.yaml",
    "validate": "test -f dist/packages/my_package/package.json && test -f dist/packages/my_package/json/my_package.json"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "devDependencies": {
    "@datasworn-community/build-tools": "0.2.6",
    "@datasworn-community/core": "0.2.6",
    "@datasworn-community/starforged": "0.2.1"
  }
}

